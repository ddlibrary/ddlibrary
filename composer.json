{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.4",
        "aws/aws-sdk-php": "^3.373",
        "barryvdh/laravel-translation-manager": "^0.6.2",
        "fakerphp/faker": "^1.23",
        "guzzlehttp/guzzle": "^7.10",
        "imagine/imagine": "^1.5",
        "jenssegers/agent": "^2.6",
        "laravel/framework": "^12.55",
        "laravel/helpers": "^1.8",
        "laravel/sanctum": "^4.3",
        "laravel/socialite": "^5.25",
        "laravel/tinker": "^2.10.1",
        "laravel/ui": "^4.6",
        "league/flysystem-aws-s3-v3": "^3.32",
        "mcamara/laravel-localization": "^2.4",
        "predis/predis": "^2.3",
        "sentry/sentry-laravel": "^4.22",
        "setasign/fpdf": "^1.8",
        "setasign/fpdi": "^2.6",
        "spatie/laravel-activitylog": "^4.12",
        "spatie/laravel-analytics": "^5.7",
        "spatie/laravel-honeypot": "^4.7",
        "tinymce/tinymce": "^8.3",
        "usmanhalalit/laracsv": "^2.1",
        "yajra/laravel-datatables-oracle": "^12.7"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3",
        "jasonmccreary/laravel-test-assertions": "^2.9",
        "laravel-shift/factory-generator": "^2.2",
        "laravel/pail": "^1.2.2"
    },
    "autoload": {
        "files": [
            "app/Support/Helpers.php",
            "app/Support/DrupalPasswordHasher.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.local', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "process-timeout": 3600
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
